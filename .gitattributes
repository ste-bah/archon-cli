# Ensures baseline + generated fixture + shell-script line endings are
# stable across Linux/macOS/Windows checkouts and marks generated
# fixture files so GitHub's linguist excludes them from language stats
# (and diffs collapse them by default).

# Baseline snapshots — plain text with stable LF endings.
tests/fixtures/baseline/*.txt text eol=lf

# Generated discovery fixtures (TASK-AGS-004 produces 300 agent files).
tests/fixtures/agents/generated/** linguist-generated=true

# Shell scripts — always LF regardless of checkout OS.
scripts/*.sh text eol=lf
