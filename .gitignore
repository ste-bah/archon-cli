# Rust build output
/target/
**/*.rs.bk

# Node / Gradle / Swift build artifacts (SDK clients)
**/node_modules/
**/.gradle/
**/build/
**/.build/

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Local config overrides (never commit secrets or machine-local config)
config.local.toml
.env
.env.*
!.env.example
.mcp.json

# Logs
*.log
logs/

# Packaging artifacts
dist/
!web/dist/
archon-*.tar.gz
archon-*.zip
.claude

# Coverage / profiling
lcov.info
*.profraw
*.profdata

# Dev-flow gate artifacts (local task tracking state)
.gates/

# Scratch / test files
hello.txt

# Local documentation (not committed).
# Use /docs/* instead of /docs/ so that negated sub-paths below can be
# re-included (git cannot re-include children of a fully excluded parent).
/docs/*
# Exception: architectural guidelines are committed (REQ-FOR-D10 et al.)
!/docs/architecture/
!/docs/architecture/**
# Exception: coverage baseline snapshot (TUI-328 / NFR-TUI-QUAL-003).
!/docs/tui-coverage-baseline.json
# Exception: phase-3 modularization final report (TUI-329).
!/docs/tui-modularization-report.md
# Exception: stage-7.5 audit artifacts (POST-6-METRICS-SWEEP et al.) —
# permanent Sherlock-verified audit records backing POST-STAGE-6 close.
# Parent dir must be negated first (git cannot re-include children of an
# excluded parent); stage-7.5/tickets/ remains ignored via /docs/* above.
!/docs/stage-7.5/
/docs/stage-7.5/*
!/docs/stage-7.5/audits/
!/docs/stage-7.5/audits/**

# Local-only artifacts (not for VCS)
FORENSIC-TASK-DECOMPOSITION.yaml
*:Zone.Identifier
.archon/leann.db
crates/archon-tui/tests/snapshots/tui_snapshots__splash_empty_activity.snap.new
crates/archon-tui/tests/snapshots/tui_snapshots__splash_with_activity.snap.new
archon
